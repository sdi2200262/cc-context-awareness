{
  "id": "simple-session-memory",
  "thresholds_file": "cc-context-awareness.thresholds.json",
  "thresholds_level_prefix": "memory-",
  "hooks": [
    { "event": "SessionStart", "matcher": "compact", "script": "hooks/session-start.sh" },
    { "event": "SessionStart", "matcher": "compact", "script": "hooks/archival.sh" },
    { "event": "PreToolUse", "matcher": "Write|Edit", "script": "hooks/approve-memory-write.sh" }
  ],
  "agents": [
    { "source": "agents/memory-archiver.md", "dest": "agents/memory-archiver.md" }
  ],
  "skills": [
    { "source": "skills/migrate/SKILL.md", "dest": "skills/migrate-simple-session-memory/SKILL.md" },
    { "source": "skills/log/SKILL.md", "dest": "skills/log-session-memory/SKILL.md" }
  ],
  "permissions": [
    "Write(.claude/memory/**)",
    "Edit(.claude/memory/**)",
    "Bash(rm -r .claude/memory/session-*)"
  ],
  "directories": ["memory", "memory/archive"],
  "claude_snippet": "CLAUDE.snippet.md",
  "claude_snippet_marker": "Session Memory System"
}
